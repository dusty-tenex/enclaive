# ── enclaive Environment Configuration ────────────────────────────────
#
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#

# ── Required ──────────────────────────────────────────────────────────

# Your Anthropic API key.
# In sandbox mode, this is injected via the Docker credential proxy
# and never enters the VM. In standalone mode, it is read directly.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Guardrails Sidecar ──────────────────────────────────────

# URL of the guardrails sidecar validation server.
# Default: http://localhost:8000
# GUARDRAILS_SIDECAR_URL=http://localhost:8000

# If set to 1, hooks will refuse to fall back to inline analysis when
# the sidecar is unreachable (fail-closed). Unset = inline fallback.
# GUARDRAILS_REQUIRE_SIDECAR=

# ── Optional: Hub Validators ─────────────────────────────────────────

# Token for guardrails-ai Hub (free from hub.guardrailsai.com).
# Without this, SecretsPresent and GuardrailsPII validators are not
# available and guards fall back to custom-only detection.
# GUARDRAILS_TOKEN=gdk-...

# ── Optional: HuggingFace (ML Models) ──────────────────────────────

# HuggingFace token for downloading gated ML models at Docker build time.
# Get a Read token from https://huggingface.co/settings/tokens
# You must also accept the model licenses:
#   - https://huggingface.co/protectai/deberta-v3-base-prompt-injection-v2
#   - https://huggingface.co/meta-llama/Prompt-Guard-2-86M
# Without this, the sidecar runs with Hub validators only (no ML ensemble).
# HF_TOKEN=hf_...

# ── Optional: Haiku Screening ────────────────────────────────────────

# If set to 1, enables the Haiku LLM classifier for inline mode.
# Requires ANTHROPIC_API_KEY. Costs ~$0.001 per call.
# SECURITY_GUARD_HAIKU=

# ── Optional: Project Path ───────────────────────────────────────────

# Path to your project directory (default: current directory).
# Used by setup.sh when configuring a project.
# PROJECT_DIR=/path/to/your/project

# ── Notes ─────────────────────────────────────────────────────────────
#
# Plugin audit policy is configured in plugins.json, not here:
#   "audit": { "api": "local", "policy": "fail-closed" }
#
# Guard bypass is controlled via read-only mount at /etc/sandbox-guards/
# (host-only, agent cannot modify). Use: make bypass-guards / make reset-guards
